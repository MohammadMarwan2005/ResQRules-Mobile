  "screen:instruction": {
    "session_id": "sample",
    "alive": true,
    "screen": {
      "type": "instruction",
      "node_id": "cpr_01",
      "chart_id": "cpr_adult",
      "chart_title": {
        "en": "Cardio-Respiratory Arrest Adult (signs of puberty are visible)",
        "ar": "السكتة القلبية التنفسية للبالغين (مع ظهور علامات البلوغ)"
      },
      "page": 3,
      "text": {
        "en": "Patient evaluation: no sign of life. (Unresponsive; open the airway chin lift / jaw thrust; check-listen-feel max 10 sec; gasping is not considered efficient breathing; don't waste time checking pulse; evidence of trauma: consider maintaining the head-neck-trunk axis until final immobilisation.)",
        "ar": "تقييم المريض: لا توجد علامة حياة. (لا يستجيب؛ افتح مجرى الهواء بإمالة الرأس/دفع الفك؛ افحص-استمع-اشعر لا يزيد عن 10 ثوانٍ؛ اللهث لا يُعدّ تنفساً فعّالاً؛ لا تضيّع الوقت في فحص النبض؛ في حال وجود رضح: فكّر في الحفاظ على محور الرأس والرقبة والجذع حتى التثبيت النهائي.)"
      },
      "options": [
        {
          "id": 1,
          "label": {
            "en": "Continue",
            "ar": "متابعة"
          }
        }
      ],
      "cf": null,
      "hem_tier": null,
      "is_terminal": false,
      "stub_target": null
    },
    "override_event": null,
